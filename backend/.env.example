# GPS51 / GPSPOS API credentials
GPS51_BASE_URL=http://www.gpspos.net
GPS51_USERNAME=your_gps51_username
GPS51_PASSWORD=your_gps51_password   # plain text (backend handles auth)

# JWT secrets — generate two separate random 64-char hex strings:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-minimum-32-chars
TENANT_JWT_SECRET=change-this-to-a-different-random-secret-minimum-32-chars

# PostgreSQL (Supabase, Neon, or self-hosted)
# Format: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# CORS — comma-separated allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081

# Wildcard CORS for production subdomains (regex — leave blank to disable)
ALLOWED_ORIGIN_REGEX=https://[a-zA-Z0-9-]+\.fleettracker\.app

# Server port
PORT=8001
