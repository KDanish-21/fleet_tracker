# GPS51 API
GPS51_BASE_URL=https://api.gps51.com
GPS51_USERNAME=your_gps51_username
GPS51_PASSWORD=your_gps51_password_md5  # MD5 32-bit lowercase

# App
SECRET_KEY=change-this-to-a-random-secret-key-minimum-32-chars
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Server
PORT=8000
