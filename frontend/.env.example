# API base URL (only needed for production builds on a custom domain)
# In development, Vite proxy handles /api → localhost:8001 (see vite.config.js)
# VITE_API_BASE_URL=https://fleet-tracker-5od4.onrender.com

# Default tenant slug for local development (when running on localhost,
# subdomain detection is disabled — use this as a fallback)
VITE_TENANT_SLUG=demo
