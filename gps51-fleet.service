[Unit]
Description=GPS51 Fleet Tracker Backend
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/var/www/gps51-fleet/backend
ExecStart=/var/www/gps51-fleet/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
